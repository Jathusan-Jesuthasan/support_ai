# =====================================================================
# SupportAI Backend Environment Variables Template
# =====================================================================

# FastAPI Application Settings
APP_NAME=SupportAI
APP_ENV=development
DEBUG=true
PORT=8000
HOST=0.0.0.0

# CORS Whitelist Settings (comma separated list of strings)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Centralised Database Settings
MONGODB_URL=mongodb://localhost:27017/supportai
REDIS_URL=redis://localhost:6379/0

# Celery Broker and Queue Settings
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# JWT Security Configurations
JWT_SECRET_KEY=ReplaceWithAReallySecureRandomSecretKeyString123!
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Generative AI Credentials (Gemini API)
# Get a key from: https://aistudio.google.com/
GEMINI_API_KEY=AIzaSyDummyKeyForTesting
